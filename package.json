{
  "name": "debugmate-ai",
  "version": "0.1.0",
  "description": "AI-powered backend service for analyzing and storing API debugging history.",
  "main": "dist/server.js",
  "type": "commonjs",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
  "dev": "tsx watch src/server.ts",
  "build": "tsc",
  "start": "node dist/server.js",
