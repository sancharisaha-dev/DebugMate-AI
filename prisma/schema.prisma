generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

model User {
  id           String @id @default(cuid())
  name         String
  email        String @unique
  passwordHash String

  errorReports  ErrorReport[]
  searchHistory SearchHistory[]
  apiUsage      ApiUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model ErrorReport {
  id          String @id @default(cuid())
  title       String
  description String?
  rawError    String
  language    String
  framework   String?
  endpoint    String?
  httpMethod  HttpMethod?
  severity    Severity @default(MEDIUM)
  status      ReportStatus @default(OPEN)

  fingerprint String? @unique

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysis AIAnalysis?
  tags     Tag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([fingerprint])
  @@index([status])
  @@index([severity])
}

model AIAnalysis {
  id String @id @default(cuid())

  summary     String
  rootCause   String
  explanation String

  severity Severity

  confidence Int

  fixes      Json
  prevention Json

  provider String
  model    String

  errorReportId String @unique
  errorReport   ErrorReport @relation(fields: [errorReportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([provider])
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  reports ErrorReport[]

  createdAt DateTime @default(now())
}

model SearchHistory {
  id    String @id @default(cuid())
  query String

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model ApiUsage {
  id String @id @default(cuid())

  provider String
  model    String

  promptTokens     Int
  completionTokens Int
  totalTokens      Int

  processingTimeMs Int

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}